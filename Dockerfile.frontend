FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

RUN npm install -g serve

CMD ["sh", "-c", "API_URL=\"${VITE_API_URL:-${vite_api_url:-}}\"; printf 'window.__APP_CONFIG__ = { VITE_API_URL: \"%s\" };\\n' \"${API_URL}\" > /app/dist/env.js && serve -s dist -l ${PORT:-8080}"]
